{
  "name": "salary-cipher",
  "packageManager": "pnpm@8.15.6",
  "description": "Salary Cipher is a project that allows you to encrypt your salary data using FHEVM.",
  "license": "MIT",
  "homepage": "https://github.com/BTBMan/salary-cipher/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BTBMan/salary-cipher.git"
  },
  "keywords": [
    "fhevm",
    "zama",
    "salary",
    "cipher"
  ],
  "engines": {
    "node": ">=22.15.0",
    "pnpm": ">=8.15.6"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "hh": "hardhat --tsconfig ./tsconfig.hardhat.json",
    "chain": "pnpm hh node --network hardhat",
    "compile": "pnpm hh compile",
    "test": "pnpm hh test",
    "coverage": "cross-env SOLIDITY_COVERAGE=true pnpm hh coverage",
    "deploy:local": "pnpm hh --network localhost ignition deploy",
    "deploy:sepolia": "pnpm hh --network sepolia ignition deploy",
    "verify:sepolia": "pnpm hh verify --network sepolia",
    "vars": "pnpm hh vars",
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "shadcn": "shadcn",
    "clean": "rimraf ./fhevmTemp ./artifacts ./cache ./coverage ./coverage.json ./dist ./ignition/deployments"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fhevm/mock-utils": "^0.4.2",
    "@fhevm/solidity": "^0.11.1",
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "^5.97.0",
    "@zama-fhe/relayer-sdk": "0.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "encrypted-types": "^0.0.4",
    "ethers": "^6.16.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "server-only": "^0.0.1",
    "shadcn": "^4.2.0",
    "solady": "^0.1.26",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.43.0",
    "wagmi": "^3.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@fhevm/hardhat-plugin": "^0.4.2",
    "@next/eslint-plugin-next": "^16.2.2",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-viem": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox-viem": "^4.1.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/chai": "^4.2.0",
    "@types/chai-as-promised": "^7.1.6",
    "@types/mocha": ">=9.1.0",
    "@types/node": ">=22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chai": "^4.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "hardhat": "^2.14.0",
    "hardhat-gas-reporter": "^2.3.0",
    "rimraf": "^6.1.3",
    "solidity-coverage": "^0.8.0",
    "tailwindcss": "^4",
    "ts-node": ">=8.0.0",
    "typescript": "^5.1.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "typescript": "*",
        "zod": "*"
      }
    }
  }
}
