{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    // "composite": true,
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "types": ["node", "mocha", "chai", "chai-as-promised"],
    "noEmit": true
  },
  "include": [
    "hardhat.config.ts",
    "ignition/**/*.ts",
    "test/**/*.ts",
    "utils/**/*.ts",
    "artifacts/**/*"
  ],
  "exclude": ["node_modules"]
}
